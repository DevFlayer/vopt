# Copie para .env e preencha. NUNCA commite o .env no Git.

# Django — gere com: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=TROQUE_PARA_UM_SEGREDO_LONGO_E_ALEATORIO

APP_ENV=development           # production | development
ALLOWED_HOSTS=localhost,127.0.0.1
ALLOWED_ORIGINS=http://localhost:3000,https://seusite.com.br

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=vopt_db

# JWT
JWT_EXPIRE_MINUTES=60
